{
  "resources": {
    "postgres": {
      "type": "container.v0",
      "connectionString": "Host={postgres.bindings.tcp.host};Port={postgres.bindings.tcp.port};Username=postgres;Password={postgres-password.value}",
      "image": "docker.io/library/postgres:17.6",
      "volumes": [
        {
          "name": "airbnb_pg_data",
          "target": "/var/lib/postgresql/data",
          "readOnly": false
        }
      ],
      "env": {
        "POSTGRES_HOST_AUTH_METHOD": "scram-sha-256",
        "POSTGRES_INITDB_ARGS": "-c wal_level=logical",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "{postgres-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "port": 5435,
          "targetPort": 5432
        }
      }
    },
    "userdb": {
      "type": "value.v0",
      "connectionString": "{postgres.connectionString};Database=userdb"
    },
    "userdb-mcp": {
      "type": "container.v0",
      "image": "docker.io/crystaldba/postgres-mcp:0.3.0",
      "args": [
        "--access-mode=unrestricted",
        "--transport=sse"
      ],
      "env": {
        "DATABASE_URI": "postgresql://postgres:{postgres-password-uri-encoded.value}@{postgres.bindings.tcp.host}:{postgres.bindings.tcp.port}/userdb"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 8000
        }
      }
    },
    "propdb": {
      "type": "value.v0",
      "connectionString": "{postgres.connectionString};Database=propdb"
    },
    "propdb-mcp": {
